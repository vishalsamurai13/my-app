    "@fastify/static": "^8.2.0",
    "@prisma/client": "^6.16.1",
    "dotenv": "^17.2.1",
    "fastify": "^5.6.0",
    "fastify-plugin": "^5.0.1",
    "mime-types": "^3.0.1",
    "prisma": "^6.16.1",
    "tsx": "^4.20.5",
    "uuid": "^11.1.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.3.0",
    "tsc-alias": "^1.8.16",
