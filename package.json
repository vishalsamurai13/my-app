{
  "name": "ai-clipart-generator",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "npm --workspace @ai-clipart/mobile run start",
    "dev:api": "npm --workspace @ai-clipart/api run dev",
    "android": "npm --workspace @ai-clipart/mobile run android",
    "ios": "npm --workspace @ai-clipart/mobile run ios",
    "web": "npm --workspace @ai-clipart/mobile run web",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "prisma:generate": "npm --workspace @ai-clipart/api run prisma:generate"
  }
}
